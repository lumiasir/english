# =============================================================
# ENGLISH Platform — Environment Variables
# =============================================================
# Copy file này thành .env.local / .env.staging / .env.production
# rồi điền giá trị thật tương ứng với từng môi trường.
# =============================================================

# --- Supabase --------------------------------------------------
# Lấy từ: Supabase Dashboard → Project Settings → API
# Local: supabase start → output ra API URL + anon key
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Chỉ dùng server-side (KHÔNG NEXT_PUBLIC_)
# Lấy từ: Supabase Dashboard → Project Settings → API → service_role
SUPABASE_SERVICE_ROLE_KEY=

# --- AI / Open Router ------------------------------------------
# Lấy từ: https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Model failback — Founder chọn khi triển khai AI
# Định dạng: 'provider/model' (vd: 'anthropic/claude-sonnet-4.6')
AI_FAILBACK_1_MODEL=
AI_FAILBACK_2_MODEL=

# --- Cron Jobs (Vercel Cron) -----------------------------------
# Sinh ngẫu nhiên: openssl rand -hex 32
CRON_SECRET=

# --- Cloudflare R2 (media storage) -----------------------------
# Phase 05 mới dùng — để placeholder trước
# CLOUDFLARE_R2_ACCOUNT_ID=
# CLOUDFLARE_R2_ACCESS_KEY_ID=
# CLOUDFLARE_R2_SECRET_ACCESS_KEY=
# CLOUDFLARE_R2_PUBLIC_URL=

# --- Azure Pronunciation Assessment (Speaking chấm điểm — Phase 07) ---
# ⚠️ Chỉ dùng để chấm điểm phát âm (Pronunciation Assessment).
# TTS/đọc giọng nói → dùng edge-tts (free, không cần API key).
# AZURE_SPEECH_KEY=
# AZURE_SPEECH_REGION=

# --- Sentry (Error Monitoring) ---------------------------------
# Lấy từ: https://sentry.io → Create Project → Next.js
# NEXT_PUBLIC_SENTRY_DSN=
# SENTRY_AUTH_TOKEN=

# --- Ngân hàng nhận VietQR -------------------------------------
# Phase 13 mới dùng — để placeholder trước
# BANK_ACCOUNT_NUMBER=
# BANK_ACCOUNT_NAME=
# BANK_NAME=
# BANK_API_KEY=
# BANK_WEBHOOK_SECRET=
